# Rust
/target
**/target
# Cargo.lock IS committed: this workspace builds a binary (forge-backend), and a
# committed lockfile gives reproducible builds and lets Dependabot/OSV scan pinned deps.

# Go
/go/**/*.exe
go/**/bin/

# Node / web
node_modules/
web/dist/
web/build/

# Env / secrets — never commit
.env
*.pem
*.key
*.p12
keystore/
*.kek
.certs/
.smoke-certs/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
