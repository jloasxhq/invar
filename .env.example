# stablecoin-forge backend configuration (copy to .env; do NOT commit real secrets).
# The service is HTTPS-only and zero-trust by default.

# Address the API binds to (TLS). Use 0.0.0.0:8443 in a container.
FORGE_BIND=0.0.0.0:8443

# Bootstrap admin account id (holds all roles at startup).
FORGE_ADMIN=issuer

# Token identity.
FORGE_TOKEN_NAME=Generic USD
FORGE_TOKEN_SYMBOL=gUSD
FORGE_TOKEN_DECIMALS=2

# Zero-trust: capability tokens are REQUIRED by default on privileged endpoints.
# Set to false ONLY for local development.
FORGE_REQUIRE_CAPS=true

# HTTPS is mandatory — provide PEM paths for the server certificate and key.
# (scripts/run.sh and the container entrypoint auto-generate a self-signed pair
#  if these are unset; provide real certs in production.)
FORGE_TLS_CERT=./.certs/cert.pem
FORGE_TLS_KEY=./.certs/key.pem
