# stablecoin-forge backend configuration (copy to .env; do NOT commit real secrets).
# All values below are the built-in defaults.

# Address the API binds to. Use 0.0.0.0:8080 in a container.
FORGE_BIND=127.0.0.1:8080

# Bootstrap admin account id (holds all roles at startup).
FORGE_ADMIN=issuer

# Token identity.
FORGE_TOKEN_NAME=Generic USD
FORGE_TOKEN_SYMBOL=gUSD
FORGE_TOKEN_DECIMALS=2

# When true, privileged endpoints REQUIRE a valid capability token
# (X-Forge-Capability header). When false (dev), a missing token falls back to
# the bootstrap admin. Set to true for anything beyond local development.
FORGE_REQUIRE_CAPS=false
